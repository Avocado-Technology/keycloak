# Keycloak admin (master realm)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-local-only

# PostgreSQL
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=keycloak

# AVCD realm
KEYCLOAK_REALM=avcd
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_API_AUDIENCE=https://dev.avcd.ai/api

# E2E validation client (defined in config/avcd-realm.json)
KEYCLOAK_TEST_CLIENT_ID=avcd-validation
KEYCLOAK_TEST_CLIENT_SECRET=local-validation-secret-ci-only
KEYCLOAK_TEST_USER=dev@avcd.local
KEYCLOAK_TEST_PASSWORD=DevPassword123!
